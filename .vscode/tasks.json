{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "icon": {
                "id": "tools",
                "tooltip": "构建项目"
            },
            "command": "cmake -S . -B build && make -C build",
        },
        {
            "label": "clean",
            "type": "shell",
            "icon": {
                "id": "flame",
                "tooltip": "清理项目"
            },
            "command": "rm -rf build",
        },
        {
            "label": "rebuild",
            "type": "shell",
            "icon": {
                "id": "rocket",
                "tooltip": "重新编译项目"
            },
            "command": "rm -rf build && cmake -S . -B build && make -C build",
        },
        {
            "label": "run",
            "type": "shell",
            "icon": {
                "id": "gear",
                "tooltip": "运行项目"
            },
            "command": "./build/bin/cli_init",
        },
    ]
}